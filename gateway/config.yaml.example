# Claude Gateway Configuration
# Copy this file to config.yaml and fill in your values.
# Environment variables can be referenced with ${VAR_NAME} syntax.

identity:
  user_name: User
  assistant_name: Assistant
  email: you@example.com
  github_login: your-github-username
  launchd_prefix: com.vadims
  timezone: UTC
  language: en

paths:
  # project_root auto-detects from the config file location. Uncomment to override.
  # project_root: ~/Documents/GitHub/claude
  obsidian_vault: ~/Documents/MyBrain
  deals_dir: ~/Documents/MyBrain/Deals
  vadimgest_url: http://localhost:8484
  claude_cli: __CLAUDE_CLI__
  node_bin: __NODE_DIR__
  homebrew_bin: /opt/homebrew/bin
  launch_agents: ~/Library/LaunchAgents
  home_claude_dir: ~/.claude
  feed_log: ~/.claude/feed/messages.jsonl

telegram:
  bot_token: ${TG_BOT_TOKEN}
  chat_id: 0
  allowed_users:
  - 0
  stream_mode: draft
  draft_throttle_ms: 300

webhook:
  enabled: true
  # Bind to localhost by default. The dashboard's /api/* surface includes
  # state-mutating endpoints (PATCH /api/settings, daemon restart,
  # /api/self-evolve/run, etc.). Change to 0.0.0.0 only if you also set
  # `token` and either keep `require_auth: auto` (loopback bypass only)
  # or `require_auth: always` (token required for every mutation).
  host: 127.0.0.1
  port: 18788
  token: ${WEBHOOK_TOKEN}
  # Auth policy for mutating verbs (POST/PATCH/DELETE/PUT). One of:
  #   auto    — require token unless the request is from 127.0.0.1/::1
  #             (default; safe for `host: 0.0.0.0` if your token is
  #             strong, since LAN clients never bypass)
  #   always  — require token for every mutation, even from loopback
  #   never   — no token check (legacy / single-user behind reverse proxy)
  # GET endpoints are never gated — they're read-only.
  require_auth: auto
  # Same-origin only by default. Widening this to '*' lets any site
  # the user visits drive the dashboard via Socket.IO; only do that
  # for explicit cross-origin tooling.
  cors_origins: 'http://localhost:18788'
  rate_limit_per_hour: 100

sessions:
  cleanup_cutoff_seconds: 300
  stuck_cutoff_seconds: 14400
  reaper_max_age_seconds: 10800
  persistent_idle_timeout: 300

cron:
  enabled: true

heartbeat:
  interval_minutes: 60

tasks:
  model: sonnet
  timeout: 1800
  gtasks_list: My Tasks  # name from integrations.google.tasks_lists

main_session:
  enabled: true
  session_key: main

subagents:
  enabled: true
  max_concurrent: 3
  default_model: sonnet
  default_timeout: 600
  announce_mode: direct
  tools: '*'
  output_dir: /tmp/claude_subagents

models:
  default: sonnet

timeouts:
  question_seconds: 300
  plan_approval_seconds: 600
  comms_approval_seconds: 600

# Optional integrations - leave blank or remove to disable
integrations:
  github:
    token: ${GITHUB_PERSONAL_ACCESS_TOKEN}
  gemini:
    api_key: ${GEMINI_API_KEY}
  obsidian:
    api_key: ${OBSIDIAN_API_KEY}
  google:
    # Path to the gog CLI binary. Defaults to ~/bin/gog.
    # cli_binary: /opt/homebrew/bin/gog
    tasks_lists:
      My Tasks: your-google-tasks-list-id
