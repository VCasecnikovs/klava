# Copy to .env and fill in what you need. Empty values disable the feature.
# setup.sh copies this to .env on first run.

# ─── Required for dashboard ────────────────────────────────────────────────

# Shared secret for the dashboard/webhook server.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_TOKEN=


# ─── Telegram (bot notifications + optional user-session reading) ──────────

# Bot for proactive notifications and inbound chat. Get from @BotFather.
TG_BOT_TOKEN=

# MTProto user session for reading your own chats (telethon). Get from
# https://my.telegram.org. Both TELEGRAM_* and TELETHON_* names are read in
# different parts of the stack — fill both with the same values.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION_STRING=


# ─── GitHub (gh-backed skills, issue syncing) ──────────────────────────────

GITHUB_PERSONAL_ACCESS_TOKEN=


# ─── Google (Gmail / Calendar / Tasks / Drive via OAuth) ───────────────────
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=


# ─── Optional ──────────────────────────────────────────────────────────────

# Google Gemini — used by /gemini-cli skill and some research flows.
GEMINI_API_KEY=

# Obsidian Local REST API plugin token (enables obsidian CLI over HTTP).
OBSIDIAN_API_KEY=

# Signal — your phone number (with +countrycode) if you use signal-cli/MCP.
SIGNAL_USER_ID=
