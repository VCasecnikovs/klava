{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "permissions": {
    "allow": [
      "Edit(~/.claude/**)",
      "Write(~/.claude/**)",
      "Edit(~/Documents/MyBrain/**)",
      "Write(~/Documents/MyBrain/**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(python3:*)",
      "Bash(pip install:*)",
      "Bash(launchctl:*)",
      "Bash(pkill:*)",
      "Bash(pgrep:*)",
      "Bash(kill:*)",
      "Bash(ps:*)",
      "Bash(curl:*)",
      "Bash(gh:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 __REPO_DIR__/gateway/hooks/qq-detector.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 __REPO_DIR__/gateway/hooks/pipeline-context.py",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 __REPO_DIR__/gateway/hooks/log-tool.py",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 __REPO_DIR__/gateway/hooks/compaction-notify.py",
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __REPO_DIR__/gateway/hooks/compaction-done.py",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "__REPO_DIR__/gateway/statusline.sh",
    "padding": 2
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {}
}
